@model List<Reservation>
@{
    ViewData["Title"] = "Pending reservations";
}

<h2>Pending reservations</h2>

@if (Model.Count == 0)
{
    <p>No pending reservations.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr><th>Visitor</th><th>Flight</th><th>Departure</th><th>Seats</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Visitor.UserName</td>
                    <td>@r.Flight.Origin → @r.Flight.Destination</td>
                    <td>@r.Flight.DepartureDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@r.NumberOfSeats</td>
                    <td>
                        <form asp-action="Approve" method="post" asp-route-id="@r.Id">
                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/reservationHub").build();
        connection.on("ReservationCreated", () => {location.reload();});
        connection.start().catch(err => console.error(err));
    </script>
}

@model List<Reservation>
@{
    ViewData["Title"] = "My reservations";
}

<h2>My reservations</h2>

@if (Model.Count == 0)
{
    <p>You have no reservations yet.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr><th>From</th><th>To</th><th>Departure</th><th>Seats</th><th>Status</th><th>Created</th></tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Flight.Origin</td>
                    <td>@r.Flight.Destination</td>
                    <td>@r.Flight.DepartureDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@r.NumberOfSeats</td>
                    <td>@r.Status</td>
                    <td>@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}